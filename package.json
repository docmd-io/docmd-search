{
  "name": "@docmd-search/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Universal offline semantic search engine.",
  "scripts": {
    "dev": "pnpm --filter docs dev",
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/*/site >/dev/null 2>&1;"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
